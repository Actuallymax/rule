DOMAIN,signin.cafr.ebay.ca
DOMAIN,signin.ebay.at
DOMAIN,signin.befr.ebay.be
DOMAIN,signin.benl.ebay.be
DOMAIN,signin.ebay.ie
DOMAIN,signin.ebay.nl
